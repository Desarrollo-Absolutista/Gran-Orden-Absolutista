{
  "name": "SanSebastian",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "$path": "src/shared",
      "$ignoreUnknownInstances": true
    },

    "ServerStorage": {
      "$path": "src/serverStorage"
    },

    "ServerScriptService": {
      "$path": "src/server"
    },

    "StarterPlayer": {
      "StarterPlayerScripts": {
        "$path": "src/client"
      }
    },

    "Workspace": {
      "$properties": {
        "FilteringEnabled": true
      }
    },

    "SoundService": {
      "$properties": {
        "RespectFilteringEnabled": true
      }
    }
  }
}